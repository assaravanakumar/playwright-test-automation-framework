{
  "name": "playwright-test-automation-framework",
  "version": "1.0.0",
  "description": "Playwright + JavaScript end-to-end and API test automation framework (POM, fixtures, data-driven, cross-browser, CI/CD)",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://www.saucedemo.com"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
